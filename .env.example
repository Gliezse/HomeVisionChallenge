# Copy to a local `.env` (not committed):
#   cp .env.example .env
#
# Uncomment and set only what you want to override. Otherwise the app uses
# the built-in defaults (see README).
#
# VITE_API_BASE=https://staging.homevision.co/api_project/houses
# VITE_INQUIRY_EMAIL=inquiry@homevision-fake-address.com
# VITE_INQUIRY_SUBJECT=Inquiry about a house

# Docker Compose: host port for the web service (default 8080 if unset)
# PORT=8080
